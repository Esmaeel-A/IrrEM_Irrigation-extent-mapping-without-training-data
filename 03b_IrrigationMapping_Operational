  // Function calcualte Optram SM as well as Relative difference for each pixel at footprint mean and at neigbourhood mean
  function OptramReady(img) {
    var ndvi = img.normalizedDifference(["nir", "red"]).rename("ndvi").float();
    var Rswir = img.select('swir1').rename('Rswir');
    var STR = img.expression(
      '((Rswir - 1) * (Rswir - 1)) / (2 * Rswir)', 
      {'Rswir': Rswir}
    ).rename('STR');

    return ee.Image.cat(ndvi, STR) 
      .copyProperties(img, ['system:time_start']);
  }


  // ==============================================================================
