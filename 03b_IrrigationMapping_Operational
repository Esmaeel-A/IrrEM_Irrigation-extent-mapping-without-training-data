// ==============================================================================
// BITWISE DECODING SCRIPT (UNPACKING)
// ==============================================================================
// Create a reusable function to unpack any specific year
function unpackYearlyData(packedImage) {
  
  // Select the specific 16-bit band for the year (e.g., 'Irrigation_2024')
  var packedBand = packedImage.select('Packed_Irr_' + 2023);
  
  // ----------------------------------------------------------------------------
  // 1. RECOVER SUMMER (Bits 0-4 | Shift: 0 | Mask: 31)
  // ----------------------------------------------------------------------------
  var summerRaw = packedBand.bitwiseAnd(31).subtract(1);
  var summerClean = summerRaw.updateMask(summerRaw.gte(0)).rename('Summer');

  // ----------------------------------------------------------------------------
  // 2. RECOVER SUP 2 (Bits 5-8 | Shift: 5 | Mask: 15)
  // ----------------------------------------------------------------------------
  var sup2Raw = packedBand.rightShift(5).bitwiseAnd(15).subtract(1);
  var sup2Clean = sup2Raw.updateMask(sup2Raw.gte(0)).rename('Sup2');

  // ----------------------------------------------------------------------------
  // 3. RECOVER SUP 1 (Bits 9-12 | Shift: 9 | Mask: 15)
  // ----------------------------------------------------------------------------
  var sup1Raw = packedBand.rightShift(9).bitwiseAnd(15).subtract(1);
  var sup1Clean = sup1Raw.updateMask(sup1Raw.gte(0)).rename('Sup1');

  // Combine them back into a clean, physical 3-band image
  return ee.Image.cat([summerClean, sup2Clean, sup1Clean]);
}
