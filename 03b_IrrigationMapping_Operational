  // ==============================================================================
  // 5. Calculate SM OPTRAM and Relative Differences
  // ==============================================================================

  // Function calcualte  Relative difference for each pixel at footprint mean and at neigbourhood mean

  function Calc_SM_RD(img) {
    // Mask out water, urban, and tree only
    var OptramReady = img.updateMask(img.select('STR')).updateMask(NotMask); 

    // Get OPTRAM parameters calculated earlier
    var iw = ee.Number(params.get(0));
    var id = ee.Number(params.get(1));
    var sd = ee.Number(params.get(2));
    var sw = ee.Number(params.get(3));

    // Calculate SM OPTRAM
    var Optram_SM = OptramReady.expression(
      '(id + sd * ndvi - STR) / (id - iw + (sd - sw) * ndvi)', {
        'id': id, 
        'sd': sd, 
        'ndvi': OptramReady.select('ndvi'), 
        'STR': OptramReady.select('STR'), 
        'iw': iw, 
        'sw': sw
      }
    ).rename('SM');
      
    // Calculate the spatial mean of the entire footprint (clamp outlier)
    var Sj = ee.Number(
      Optram_SM.select('SM')
        .clamp(0, 5)
        .reduceRegion({
          reducer: ee.Reducer.mean(), 
          geometry: LandsatFootprintGeom, 
          scale: 30,
          maxPixels: 1e13
        }).get("SM")
    );
    
    // Calculate relative difference for each pixel based on the entire footprint
    var RD = Optram_SM.select('SM').subtract(Sj).divide(Sj).toFloat().rename('RD');
   
    // Calculate the relative difference for each neighborhood
    var localWindow = ee.Kernel.square({
      radius: 2500, 
      units: 'meters'
    }); 
    
    var Sj_local = Optram_SM.select('SM')
      .clamp(0, 5)
      .reduceNeighborhood({
        reducer: ee.Reducer.mean(),
        kernel: localWindow,
        optimization: 'boxcar' 
      }).rename('SM_local_mean');
      
    var RD_local = Optram_SM.select('SM').subtract(Sj_local).divide(Sj_local).toFloat().rename('RD_local');
   
    return ee.Image.cat(Optram_SM, img.select('pr'), RD, Sj_local, RD_local)      
      .copyProperties(img, ['system:time_start']);
  }



  // ==============================================================================
  // 6. FORWARD DIFFERENCING (ARRAY BASED)
  // ==============================================================================

  function ForwardDifferencing(collection) {
    var withDoys = collection.map(function(image) {
      var date = image.date();
      var doy = date.getRelative('day', 'year');
      var time = image.metadata('system:time_start');
      
      var doyImage = ee.Image(doy)
        .rename('doy')
        .int();
        
      return image.addBands(doyImage).addBands(time)
        .copyProperties(image, image.propertyNames()); 
    });
        
    var array = withDoys.toArray();
    var timeAxis = 0;
    var bandAxis = 1;

    var subtract = function(array) {
      var time = array.arraySlice(bandAxis, -1);
      var sorted = array.arraySort(time);
      
      var doy = sorted.arraySlice(bandAxis, -2, -1);
      var image = sorted.arraySlice(bandAxis, 0, 1);
      
      var left = image.arraySlice(timeAxis, 1);
      var right = image.arraySlice(timeAxis, 0, -1);
      
      var dif = left.subtract(right);
      return dif;
    };

    var DOYdifference = subtract(array);

    var differenceCollection = withDoys.map(function(image) {
      var arrayTime = array.arraySlice(bandAxis, -1);
      arrayTime = arrayTime.arraySort(arrayTime);
      
      var timeMask = arrayTime
        .arraySlice(timeAxis, 1) // Drop first time - will not have a difference
        .eq(image.getNumber('system:time_start'))
        .arrayProject([timeAxis]);
        
      var maskedDifference = DOYdifference
        .arrayProject([timeAxis])
        .arrayMask(timeMask);
        
      var difference = maskedDifference
        .updateMask(maskedDifference.arrayLength(timeAxis))
        .arrayFlatten([['difference']]);
        
      return image.addBands(difference);
    });
    
    return differenceCollection;
  }
  // ------------------------------------------------------------------------------
  // 5. CALCULATE SM OPTRAM
  // ------------------------------------------------------------------------------


  var OPTRAM_ReadyCollection = Collection.map(OptramReady); 

  // Add matched rainfall
  OPTRAM_ReadyCollection = OPTRAM_ReadyCollection.map(MatchedSM_leftPr);
   
   
  if (CalcParams === true) {
    // Calculate Optram Global parameter 
    // NOTE: OPTRAM_ReadyCollection must be defined prior to calling this
    params = CalculateOPTRAMGlobalParams(OPTRAM_ReadyCollection);
    // Check and update params if needed
    params = checkParam(params);
  }

  // Calculate soil moisture and relative mean 


  var SM_RD_Col = OPTRAM_ReadyCollection.map(Calc_SM_RD); 

   


  // ------------------------------------------------------------------------------
  // 6. FORWARD DIFFERENCING PIPELINE
  // ------------------------------------------------------------------------------
  var differenceSM = ForwardDifferencing(SM_RD_Col);

  // Organize to calculate difference neighborhood SM
  differenceSM = differenceSM.select(
    ['SM_local_mean', 'SM', 'RD', 'pr', 'RD_local', 'difference'],
    ['SM_local_mean', 'SM', 'RD', 'pr', 'RD_local', 'diff_SM']
  );

  var differenceSM_neighbour = ForwardDifferencing(differenceSM);

  // Organize to calculate the difference in days
  differenceSM_neighbour = differenceSM_neighbour.select(
    ['doy', 'SM_local_mean', 'SM', 'RD', 'pr', 'RD_local', 'diff_SM', 'difference'],
    ['d', 'SM_local_mean', 'SM', 'RD', 'pr', 'RD_local', 'diff_SM', 'diff_SM_Local_mean']
  );

  var FinalDif = ForwardDifferencing(differenceSM_neighbour);

  FinalDif = FinalDif.select(
    ['SM_local_mean', 'SM', 'RD', 'pr', 'RD_local', 'diff_SM', 'diff_SM_Local_mean', 'difference'],
    ['SM_local_mean', 'SM', 'RD', 'pr', 'RD_local', 'diff_SM', 'diff_SM_Local_mean', 'diff_doy']
  );

  // ------------------------------------------------------------------------------
  // 7. THE GAUNTLET (NEGATIVE VETO LOGIC)
  // ------------------------------------------------------------------------------
  var DifinDif = FinalDif.map(function(img) { 
    var Validmask = img.select('diff_doy').lte(16).rename('Valid');
    var DiD = img.select('diff_SM').subtract(img.select('diff_SM_Local_mean')).rename('DifinDif');
    
    var i = Validmask.where(
      DiD.lte(0.05)                                     // Veto: Did not detect increase above noise
      .or(img.select('diff_SM').lte(0.05))              // Veto: Original SM did not increase above noise 
      .or(img.select('diff_SM_Local_mean').gte(0.05))   // Veto: Neighborhood is wetting (Ghost Storm)
      .or(img.select('pr').gt(0))                       // Veto: Rainfall occurred
      .or(img.select('RD').lte(0.05)),                  // Veto: Pixel is not significantly wetter than footprint
      0
    ).rename('Isirrigated');
    
    return img.addBands(DiD).addBands(Validmask).addBands(i);
  });

  // ------------------------------------------------------------------------------
  // 8. SEASONAL SEGMENTATION & MAPPING
  // ------------------------------------------------------------------------------

  // 1. IRRIGATION LOGIC (Using the -1 offset for No Data)
  var dummyNoData = ee.Image(-1);

  var sup1Collection = DifinDif.filter(ee.Filter.date((start_year - 1) + '-10-01', (end_year - 1) + '-11-30'));
  var sup1Irrigated = ee.Image.cat([sup1Collection.select('Isirrigated').sum(), dummyNoData])
                          .select(0).add(1).clamp(0, 15).toUint16().rename('sup1'); 

  var sup2Collection = DifinDif.filter(ee.Filter.date(start_year + '-03-01', end_year + '-04-30'));
  var sup2Irrigated = ee.Image.cat([sup2Collection.select('Isirrigated').sum(), dummyNoData])
                          .select(0).add(1).clamp(0, 15).toUint16().rename('sup2');

  var summerCollection = DifinDif.filter(ee.Filter.date(start_year + '-05-01', end_year + '-09-30'));
  var summerIrrigated = ee.Image.cat([summerCollection.select('Isirrigated').sum(), dummyNoData])
                            .select(0).add(1).clamp(0, 31).toUint16().rename('summ');

  // 2. VALID OBSERVATION LOGIC (Using a standard 0 offset, because 0 valid days is physically real)
  var dummyZero = ee.Image(0);

  var sup1Valid = ee.Image.cat([sup1Collection.select('Valid').sum(), dummyZero])
                      .select(0).clamp(0, 15).toUint16().rename('sup1_v');

  var sup2Valid = ee.Image.cat([sup2Collection.select('Valid').sum(), dummyZero])
                      .select(0).clamp(0, 15).toUint16().rename('sup2_v');

  var summerValid = ee.Image.cat([summerCollection.select('Valid').sum(), dummyZero])
                        .select(0).clamp(0, 31).toUint16().rename('summ_v');

  // ------------------------------------------------------------------------------
  // 10. COMPRESSION
  // ------------------------------------------------------------------------------
  
  // Pack Irrigation
  var packedIrrigation = summerIrrigated
    .add(sup2Irrigated.leftShift(5)) 
    .add(sup1Irrigated.leftShift(9)) 
    .toUint16().rename('Pack_Ir'+year); 

  // Pack Valid Counts (Using the exact same bit allocation)
  var packedValid = summerValid
    .add(sup2Valid.leftShift(5))
    .add(sup1Valid.leftShift(9))
    .toUint16().rename('Pack_V'+year);

  // UnPacked Irrigation
  var UnpackedIrrigation = summerIrrigated.rename('UnPack_summ_'+year)
    .addBands(sup2Irrigated.rename('UnPack_sup2_'+year)) 
    .addBands(sup1Irrigated.rename('UnPack_sup1_'+year)) 
    .toUint16(); 
    
    
  return ee.Image.cat([packedIrrigation,packedValid//,UnpackedIrrigation
    ]).set({'year': year,'WRS_Path': WRS_Path,'WRS_Row':WRS_Row
    }); 

}
